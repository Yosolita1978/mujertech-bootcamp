# Supabase — public values (safe to expose in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only secret. NEVER expose to the browser.
# Used only in server actions / route handlers / middleware.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of admin email addresses (server-only).
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=

# Analytics — public, browser-safe. Leave blank to disable.
# When blank, the corresponding component returns null (no scripts injected).
# Populate with fresh IDs per environment to avoid polluting prod analytics with dev traffic.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
